---
import { ClientRouter } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';

export type Props = HeadProps & { showHeader?: boolean };

const { showHeader = true, ...head } = Astro.props;
---

<!doctype html>
<html lang="en" class="wrap-break-words antialiased">
    <head>
        <BaseHead {...head} />
        <script is:inline src="/theme-toggle.js"></script>
        <ClientRouter />
    </head>
    
    <body class="bg-main text-main selection:bg-[#1a2f1e]/20 selection:text-[#1a2f1e] dark:selection:bg-white/20 dark:selection:text-white min-h-screen relative">
        
        <div class="fixed inset-0 -z-50" aria-hidden="true">
        <img
            src="/forest-cover.webp"
            alt=""
            class="absolute inset-0 h-full w-full object-cover opacity-50 dark:opacity-10"
            loading="eager"
            fetchpriority="low"
        />
        </div>

        <div class="flex min-h-screen flex-col px-4 md:px-8 relative z-0">
            <Nav />
            {showHeader && <Header />}
            
            <main class="mx-auto w-full max-w-3xl grow animate-fade-in">
                <slot />
            </main>
            
            <Footer />
        </div>
    </body>
</html>