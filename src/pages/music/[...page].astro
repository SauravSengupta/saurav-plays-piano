---
import type { GetStaticPathsOptions, Page } from 'astro';
import { Image } from 'astro:assets'; // Import Astro's Image component for better handling
import { type CollectionEntry, getCollection } from 'astro:content';
import Pagination from '../../components/Pagination.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const projects = (await getCollection('music')).sort(sortItemsByDateDesc);
    return paginate(projects, { pageSize: siteConfig.projectsPerPage || 6 });
}

type Props = { page: Page<CollectionEntry<'music'>> };

const { page } = Astro.props;
const portfolio = page.data;
---

<BaseLayout title="Music" description="Original ambient piano compositions and releases by Saurav Plays Piano" showHeader={false}>
    
    <h1 class="mb-12 font-sans text-2xl font-medium leading-tight sm:mb-16 sm:text-4xl text-main">
        Music
    </h1>

    <div class="grid gap-y-12 sm:gap-y-16 mt-8 mb-16">
        {portfolio.map((project) => (
            <a 
                href={`/music/${project.id}`} 
                class="group flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-8"
            >
                {/* 1. The Thumbnail Image */}
                <div class="shrink-0 relative overflow-hidden rounded-md shadow-sm sm:w-48 sm:h-48 aspect-square bg-muted">
                    {/* Check if the SEO image exists in frontmatter */}
                    {project.data.seo?.image?.src && (
                        <Image 
                            src={project.data.seo.image.src} 
                            alt={project.data.seo.image.alt || project.data.title}
                            width={400}
                            height={400}
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                    )}
                </div>

                {/* 2. The Text Info */}
                <div class="flex flex-col gap-2">
                    <h2 class="text-xl font-sans font-medium text-main group-hover:underline group-hover:underline-offset-4 decoration-1">
                        {project.data.title}
                    </h2>
                    
                    <p class="text-muted text-sm leading-relaxed max-w-prose line-clamp-3">
                        {project.data.description}
                    </p>
                    
                    <span class="mt-2 text-xs uppercase tracking-wider text-gray-500 font-medium group-hover:text-black dark:group-hover:text-white transition-colors">
                        Listen &rarr;
                    </span>
                </div>
            </a>
        ))}
    </div>

    <Pagination page={page} class="my-16 sm:my-24" />
</BaseLayout>