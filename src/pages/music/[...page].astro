---
import type { GetStaticPathsOptions, Page } from 'astro';
import { Image } from 'astro:assets'; // Import Astro's Image component for better handling
import { type CollectionEntry, getCollection } from 'astro:content';
import Pagination from '../../components/Pagination.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const tracks = (await getCollection('music')).sort(sortItemsByDateDesc);
    return paginate(tracks, { pageSize: siteConfig.tracksPerPage || 6 });
}

type Props = { page: Page<CollectionEntry<'music'>> };

const { page } = Astro.props;
const portfolio = page.data;
---

<BaseLayout title="Music" description="Original ambient piano compositions and releases by Saurav Plays Piano" showHeader={false}>
    
    <h1 class="mb-12 font-serif text-3xl font-light leading-tight sm:mb-16 sm:text-5xl sm:leading-tight text-main">
        Music
    </h1>
    
    <div class="grid gap-y-12 sm:gap-y-16 mt-8 mb-16">
        {portfolio.map((track) => (
            <a 
                href={`/music/${track.id}`} 
                class="group flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-8"
            >
                {/* 1. IMAGE WRAPPER
                    - Moved transition-all/duration here to animate shadow on the box
                    - Kept opacity transition on the image itself
                */}
                <div class="shrink-0 relative overflow-hidden rounded-md shadow-sm group-hover:shadow-xl sm:w-40 sm:h-40 aspect-square bg-muted/20 transition-all duration-700 ease-out">
                    {track.data.seo?.image?.src && (
                        <Image 
                            src={track.data.seo.image.src} 
                            alt={track.data.seo.image.alt || track.data.title}
                            width={400}
                            height={400}
                            class="h-full w-full object-cover transition-opacity duration-700 ease-out opacity-80 group-hover:opacity-100"
                        />
                    )}
                </div>

                {/* 2. TEXT INFO */}
                <div class="flex flex-col gap-2 pt-1">
                    
                    {/* --- DYNAMIC BADGE --- 
                        Only shows if you added 'badge: "..."' to the markdown file 
                    */}
                    {track.data.badge && (
                        <span class="text-[10px] font-medium tracking-[0.2em] uppercase text-main/60 mb-0.5">
                            {track.data.badge}
                        </span>
                    )}

                    {/* TITLE */}
                    <h2 class="text-2xl font-serif font-light text-main decoration-1 underline-offset-4 group-hover:underline transition-all">
                        {track.data.title}
                    </h2>
                    
                    {/* DESCRIPTION */}
                    <p class="text-main/80 text-base font-light leading-relaxed max-w-prose line-clamp-2">
                        {track.data.description}
                    </p>
                    
                    {/* --- DYNAMIC ACTION LINK --- 
                        Uses 'actionText' from markdown (e.g., "Pre-save Now") 
                        Defaults to "Listen" if empty.
                    */}
                    <span class="mt-2 font-serif italic text-main/60 group-hover:text-main transition-colors flex items-center gap-2">
                        {track.data.actionText || 'Listen'} 
                        <span class="not-italic text-xs">&rarr;</span>
                    </span>
                </div>
            </a>
        ))}
    </div>

    <Pagination page={page} class="my-16 sm:my-24" />
</BaseLayout>