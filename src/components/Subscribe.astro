---
import siteConfig from '../data/site-config';
import Button from './Button.astro';

type Props = { class?: string };

const { class: className } = Astro.props;
const subscribe = siteConfig.subscribe;
if (!subscribe?.enabled || !subscribe?.form?.action) {
    return;
}
---

<section 
    id="subscribe-card" 
    class:list={[
        'bg-black/10 backdrop-blur-md border border-white/10 rounded-2xl text-center transition-all duration-500 mx-auto',
        'p-8 sm:p-10', /* CHANGED: Reduced padding from px-8 py-16 to just p-8/p-10 */
        'max-w-2xl',   /* CHANGED: Added max-width constraint to keep it compact */
        className
    ]}
>
    {subscribe.title && (
        <h2 class="w-full mx-auto max-w-lg font-serif text-2xl leading-tight font-medium sm:text-3xl mb-3">
            {subscribe.title}
        </h2>
    )}
    
    {subscribe.text && (
        <p class="w-full mx-auto max-w-md text-sm leading-relaxed text-main mb-6">
            {/* CHANGED: Reduced margin-bottom from mb-8 to mb-6 for tighter spacing */}
            {subscribe.text}
        </p>
    )}
    
    <form
        action={subscribe.form.action}
        method="post"
        id="subscribe-form"
        name="subscribe-form"
        class="flex w-full max-w-md mx-auto flex-col gap-3 sm:flex-row"
        target="_blank"
    >
        <div class="relative w-full">
            <input
                type="email"
                name={subscribe.form.emailFieldName || 'email'}
                required
                autocomplete="email"
                placeholder="name@example.com"
                class="w-full rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm text-main placeholder:text-main/50 transition-colors focus:border-white focus:outline-none"
                aria-label="Email address"
            />
        </div>

        {subscribe.form.hiddenFields?.map((field) => <input type="hidden" name={field.name} value={field.value} />)}
        
        {
            subscribe.form.honeypotFieldName && (
                <div style="position: absolute; left: -5000px;" aria-hidden="true">
                    <input type="text" name={subscribe.form.honeypotFieldName} tabindex="-1" autocomplete="off" />
                </div>
            )
        }
        
        <Button type="submit" class="h-full w-full sm:w-auto px-8 py-3">Subscribe</Button>
    </form>
</section>

<script>
  const card = document.getElementById('subscribe-card');
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  if (form && card) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault(); 
      
      if (button) {
          button.disabled = true;
          button.innerText = 'Joining...';
      }

      const formData = new FormData(form);

      try {
        await fetch(form.action, {
          method: 'POST',
          body: formData,
          mode: 'no-cors' 
        });

        // Updated success message to match new text colors
        card.innerHTML = `
          <div class="flex flex-col items-center justify-center h-full py-4 animate-fade-in">
             <p class="font-serif text-2xl text-main">Welcome to Saurav Plays Piano.</p>
             <p class="text-sm mt-2 text-gray-400">Check your inbox to confirm.</p>
          </div>
        `;
        
      } catch (err) {
        form.submit();
      }
    });
  }
</script>