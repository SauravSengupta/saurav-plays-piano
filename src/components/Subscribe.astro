---
import siteConfig from '../data/site-config';
import Button from './Button.astro';

type Props = { class?: string };

const { class: className } = Astro.props;
const subscribe = siteConfig.subscribe;
if (!subscribe?.enabled || !subscribe?.form?.action) {
    return;
}
---

<section 
    id="subscribe-card" 
    class:list={['bg-neutral-50 dark:bg-white/5 rounded-2xl px-8 py-16 text-center sm:px-12 transition-all duration-500 ease-in-out', className]}
>
    {subscribe.title && <h2 class="w-full mx-auto max-w-xl font-serif text-2xl leading-tight font-medium sm:text-3xl mb-4">{subscribe.title}</h2>}
    {subscribe.text && <p class="w-full mx-auto max-w-prose text-sm leading-relaxed text-gray-600 dark:text-gray-400 mb-8">{subscribe.text}</p>}
    
    <form
        action={subscribe.form.action}
        method="post"
        id="subscribe-form"
        name="subscribe-form"
        class="flex w-full max-w-md mx-auto flex-col gap-3 sm:flex-row"
        target="_blank"
    >
        <div class="relative w-full">
            <input
                type="email"
                name={subscribe.form.emailFieldName || 'email'}
                required
                autocomplete="email"
                placeholder="name@example.com"
                class="w-full rounded-full border border-gray-200 bg-white dark:bg-black px-5 py-3 text-sm transition-colors focus:border-black focus:outline-none dark:border-gray-800 dark:focus:border-white"
                aria-label="Email address"
            />
        </div>

        {subscribe.form.hiddenFields?.map((field) => <input type="hidden" name={field.name} value={field.value} />)}
        
        {
            subscribe.form.honeypotFieldName && (
                <div style="position: absolute; left: -5000px;" aria-hidden="true">
                    <input type="text" name={subscribe.form.honeypotFieldName} tabindex="-1" autocomplete="off" />
                </div>
            )
        }
        
        <Button type="submit" class="h-full w-full sm:w-auto px-8 py-3">Subscribe</Button>
    </form>
</section>

<script>
  // Select both the Card (to replace content) and Form (to handle submit)
  const card = document.getElementById('subscribe-card');
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  if (form && card) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault(); 
      
      // 1. Visual Feedback on Button
      if (button) {
          button.disabled = true;
          button.innerText = 'Joining...';
      }

      const formData = new FormData(form);

      try {
        // 2. Submit silently
        await fetch(form.action, {
          method: 'POST',
          body: formData,
          mode: 'no-cors' 
        });

        // 3. Replace the ENTIRE card content with the Success Message
        card.innerHTML = `
          <div class="flex flex-col items-center justify-center h-full py-2 animate-fade-in">
             <p class="font-serif text-2xl text-main">Welcome to Saurav Plays Piano.</p>
             <p class="text-sm mt-3 opacity-80">Check your inbox to confirm your subscription.</p>
          </div>
        `;
        
      } catch (err) {
        // Fallback if JS fails
        form.submit();
      }
    });
  }
</script>