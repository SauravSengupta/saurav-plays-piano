---
import type { Hero as HeroProps } from '../types';
import Button from './Button.astro';
import CustomImage from './CustomImage.astro';

type Props = HeroProps;

const { image, text, actions } = Astro.props;
---

{
    (image?.src || text || (actions && actions.length > 0)) && (
        <section class="mb-16 flex w-full flex-col gap-8 sm:mb-24">
            {image?.src && (
                <figure class="relative w-full rounded-lg shadow-xl overflow-hidden bg-white dark:bg-muted">
                    <CustomImage
                        class="w-full opacity-70 dark:opacity-60 transition-opacity duration-500"
                        {...image}
                        widths={[480, 640, 768, 1024, 1536]}
                        sizes="(min-width: 832px) 768px, calc(100vw - 32px)"
                        fetchpriority="high"
                        loading="eager"
                    />
                    {image.caption && <figcaption class="mt-1.5 text-xs sm:text-sm px-1">{image.caption}</figcaption>}
                </figure>
            )}

            {text && <p class="prose sm:prose-lg max-w-none">{text}</p>}

            {actions && actions.length > 0 && (
                <div class="mt-6 flex flex-col gap-4 w-full sm:max-w-lg mx-auto">
                    {actions.map((action) => (
                        action.image ? (
                            <a 
                                href={action.href} 
                                class="group flex items-center bg-muted/40 backdrop-blur-md border border-main rounded-xl p-3 pr-6 shadow-lg hover:shadow-xl hover:bg-main transition-all duration-500 ease-out"
                            >
                                <div class="relative w-16 h-16 sm:w-20 sm:h-20 shrink-0 mr-4 overflow-hidden rounded-lg">
                                    <img 
                                        src={action.image} 
                                        alt={action.text} 
                                        class="w-full h-full object-cover rounded-lg shadow-sm" 
                                    />
                                </div>
                                <div class="flex flex-col text-left">
                                    {action.label && (
                                        <span class="text-[10px] uppercase tracking-[0.25em] font-medium text-main/60 mb-2 block">
                                            {action.label}
                                        </span>
                                    )}                                    
                                    
                                    <span class="font-serif text-lg text-main font-normal group-hover:text-black dark:group-hover:text-white transition-colors">
                                        {action.text} &rarr;
                                    </span>
                                </div>
                            </a>
                        ) : (
                            <div class="flex justify-center">
                                <Button href={action.href}>{action.text}</Button>
                            </div>
                        )
                    ))}
                </div>
            )}
        </section>
    )
}