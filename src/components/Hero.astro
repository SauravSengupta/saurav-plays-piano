---
import { marked } from 'marked';
import type { Hero as HeroProps } from '../types';
import Button from './Button.astro';
import CustomImage from './CustomImage.astro';

type Props = HeroProps;

const { title, image, text, actions } = Astro.props;
---

{
    (title || image?.src || text || (actions && actions.length > 0)) && (
        <section class="mb-16 flex w-full flex-col gap-8 sm:mb-24">
            {/* Updated to text-3xl / text-5xl and font-light to match PageLayout */ }
            {title && <h1 class="font-serif text-3xl font-light leading-tight sm:text-5xl sm:leading-tight text-main">{title}</h1>}
                        
            {image?.src && (
                /* UPDATED CONTAINER:
                   1. bg-white: Backs the image with white (creates the 'fade' look).
                   2. dark:bg-zinc-900: Backs it with dark gray in dark mode (creates a 'dimmed' look).
                   3. overflow-hidden: Ensures the image doesn't spill out of the rounded corners.
                */
                <figure class="relative w-full rounded-lg shadow-xl overflow-hidden bg-white dark:bg-zinc-900">
                    <CustomImage
                        /* UPDATED IMAGE CLASSES:
                           - Removed 'rounded-lg' and 'shadow-xl' (moved to parent).
                           - opacity-80: Allows the white background to bleed through slightly.
                           - mix-blend-normal: Ensures clean compositing.
                        */
                        class="w-full opacity-70 dark:opacity-60 transition-opacity duration-500"
                        {...image}
                        widths={[480, 640, 768, 1024, 1536]}
                        sizes="(min-width: 832px) 768px, calc(100vw - 32px)"
                        fetchpriority="high"
                        loading="eager"
                    />
                    {image.caption && <figcaption class="mt-1.5 text-xs sm:text-sm px-1">{image.caption}</figcaption>}
                </figure>
            )}

            {text && <div class="prose sm:prose-lg max-w-none" set:html={marked.parse(text)} />}

            {actions && actions.length > 0 && (
                <div class="mt-6 flex flex-col gap-4 w-full sm:max-w-lg mx-auto">
                    {actions.map((action) => (
                        action.image ? (
                            <a 
                                href={action.href} 
                                class="group flex items-center bg-white/30 backdrop-blur-md border border-white/40 rounded-xl p-3 pr-6 shadow-lg hover:scale-[1.02] transition-all duration-300 hover:bg-white/40 no-underline"
                            >
                                <div class="relative w-16 h-16 sm:w-20 sm:h-20 shrink-0 mr-4">
                                    <img 
                                        src={action.image} 
                                        alt={action.text} 
                                        class="w-full h-full object-cover rounded-lg shadow-sm group-hover:shadow-md transition-shadow" 
                                    />
                                </div>
                                <div class="flex flex-col text-left">
                                    {action.label && (
                                        <span class="text-[10px] uppercase tracking-[0.25em] font-medium text-main/60 mb-2 block">
                                            {action.label}
                                        </span>
                                    )}                                    
                                    
                                    <span class="font-serif text-lg text-main font-normal group-hover:text-black dark:group-hover:text-white transition-colors">
                                        {action.text} &rarr;
                                    </span>
                                </div>
                            </a>
                        ) : (
                            <div class="flex justify-center">
                                <Button href={action.href}>{action.text}</Button>
                            </div>
                        )
                    ))}
                </div>
            )}
        </section>
    )
}