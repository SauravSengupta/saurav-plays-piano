---
import siteConfig from '../data/site-config';

const navLinks = siteConfig.footerNavLinks ?? [];
const currentYear = new Date().getFullYear();
---

<footer class="mx-auto w-full max-w-3xl pt-12 pb-10 sm:pt-24 sm:pb-14">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-sm text-main">
        
        {/* 1. The Copyright Text */}
        <p>
            &copy; {currentYear} {siteConfig.title}. All rights reserved.
        </p>

        {/* 2. The Separator (Hidden on mobile, visible on desktop) */}
        {navLinks.length > 0 && (
            <span class="hidden sm:inline-block opacity-30">|</span>
        )}

        {/* 3. The Links (Terms, Privacy, etc.) */}
        {
            navLinks.length > 0 && (
                <nav aria-label="Footer navigation" class="flex gap-4">
                    {navLinks.map((link) => (
                        <a 
                            class="hover:underline hover:underline-offset-2 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" 
                            href={link.href}
                        >
                            {link.text}
                        </a>
                    ))}
                </nav>
            )
        }
    </div>
</footer>