---
import siteConfig from '../data/site-config';
import CustomImage from './CustomImage.astro';

const titleClass = 'text-theme-foreground font-serif text-2xl leading-tight font-medium sm:text-3xl';
---

<header class="mx-auto mb-12 flex w-full max-w-3xl items-center gap-4 sm:mb-16">
    <!--
    {
        siteConfig.avatar?.src && (
            <CustomImage
                /* UPDATED CLASSES HERE: Added grayscale, opacity, and hover transitions */
                class="aspect-square w-16 rounded-full object-cover sm:w-20 grayscale opacity-90 hover:grayscale-0 hover:opacity-100 transition-all duration-700 ease-out"
                {...siteConfig.avatar}
                loading="eager"
                fetchpriority="high"
                width={80}
                height={80}
                widths={[80, 160]}
                sizes="80px"
            />
        )
    }
    -->
    {
        siteConfig.logo && (
            <a href="/" aria-label="Home">
                {/* 1. Outer Container: Clips the original image out of view */}
                <div class="relative h-16 w-16 sm:h-20 sm:w-20 overflow-hidden">
                    
                    {/* 2. Inner Wrapper: Moves the real image UP, casts a colored shadow DOWN */}
                    <div style="transform: translateY(-100px); filter: drop-shadow(0 100px 0 var(--text-main));">
                        <CustomImage
                            {...siteConfig.logo}
                            class="block h-full w-full object-contain"
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>
                    
                </div>
            </a>
        )
    }
    <div class="grow">
        {
            siteConfig.avatar?.src ? (
                <p class={titleClass}>{siteConfig.title}</p>
            ) : (
                <a class={titleClass} href="/">
                    {siteConfig.title}
                </a>
            )
        }
        {siteConfig.subtitle && <p class="text-sm leading-tight">{siteConfig.subtitle}</p>}
    </div>
</header>