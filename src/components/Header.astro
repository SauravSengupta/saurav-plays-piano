---
import siteConfig from '../data/site-config';
import CustomImage from './CustomImage.astro';

/* UPDATED TYPOGRAPHY:
   1. text-main: Ensures it uses your forest green/white theme color.
   2. font-light: Matches the 'Cinematic' look of your Hero and Page titles.
   3. tracking-tight: Keeps the serif letters nicely compacted.
*/
const titleClass = 'text-main font-serif text-2xl leading-tight font-light sm:text-3xl tracking-tight';
---

<header class="mx-auto mb-12 flex w-full max-w-3xl items-center gap-4 sm:mb-16">

    {
        siteConfig.logo && (
                <div class="relative h-16 w-16 sm:h-20 sm:w-20 overflow-hidden">
                    <div style="transform: translateY(-100px); filter: drop-shadow(0 100px 0 var(--text-main));">
                        <CustomImage
                            {...siteConfig.logo}
                            class="block h-full w-full object-contain"
                            loading="eager"
                            fetchpriority="high"
                        />
                    </div>
                </div>
        )
    }

    <div class="grow">
        {
            siteConfig.avatar?.src ? (
                <p class={titleClass}>{siteConfig.title}</p>
            ) : (
                <a class={titleClass} href="/">
                    {siteConfig.title}
                </a>
            )
        }
        
        {/* SUBTITLE UPDATE: Added 'text-main/90' for softer contrast */}
        {siteConfig.subtitle && (
            <p class="text-sm leading-tight text-main/90 mt-1">
                {siteConfig.subtitle}
            </p>
        )}
    </div>
</header>