---
import { Image } from 'astro:assets';
import { type CollectionEntry } from 'astro:content';
import ArrowRight from '../assets/icons/arrow-right.svg';
import FormattedDate from './FormattedDate.astro';

type Props = { post: CollectionEntry<'musings'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { post, class: className, headingLevel = 'h2' } = Astro.props;
const { title, publishDate, updatedDate, excerpt, seo } = post.data;
const TitleTag = headingLevel;
---

<a class:list={['group flex items-start gap-4 sm:gap-6', className]} href={`/musings/${post.id}/`}>
    {seo?.image?.src && (
        <div class="shrink-0 relative overflow-hidden rounded-md shadow-sm group-hover:shadow-lg w-20 h-20 sm:w-24 sm:h-24 aspect-square bg-muted/20 transition-all duration-500 ease-out">
            <Image
                src={seo.image.src}
                alt={seo.image.alt || title}
                width={200}
                height={200}
                class="h-full w-full object-cover transition-opacity duration-500 ease-out opacity-80 group-hover:opacity-100"
            />
        </div>
    )}
    <div class="grow min-w-0">
        <TitleTag
            class="font-serif text-xl leading-tight font-light group-hover:underline group-hover:decoration-1 group-hover:underline-offset-4 sm:text-2xl text-main/90"
        >
            {title}
        </TitleTag>
        <div class="mt-1 text-sm leading-normal text-main/90">
            <FormattedDate date={publishDate} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            (Updated on <FormattedDate date={updatedDate} />)
                        </span>
                    </>
                )
            }
        </div>
        {excerpt && <div class="mt-3 text-sm leading-normal">{excerpt}</div>}
    </div>
    <div class="hidden font-serif opacity-0 transition group-hover:opacity-100 sm:inline-flex sm:shrink-0 sm:items-center sm:gap-1 text-main/90">
        Read <ArrowRight class="h-4 w-4 fill-current" />
    </div>
</a>
