---
import type { Page } from 'astro';

type Props = { page: Page<unknown>; class?: string };

const { page, class: className } = Astro.props;
---

<nav 
    aria-label="Pagination" 
    class:list={[
        /* Layout: Flexbox for centering, added padding for breathing room */
        'flex items-center justify-center gap-8 py-8 sm:py-12', 
        className
    ]}
>
    {/* 1. PREVIOUS LINK */}
    {
        page.url.prev ? (
            <a
                href={page.url.prev}
                class="font-serif italic text-lg text-main/60 hover:text-main transition-colors"
                aria-label={`Go to page ${page.currentPage - 1} of ${page.lastPage}`}
            >
                &larr; Prev
            </a>
        ) : (
            /* Spacer: Keeps the center text perfectly centered even on the first page */
            <span class="w-[60px]" aria-hidden="true"></span>
        )
    }

    {/* 2. THE PAGE INDICATOR: Serif, Italic, and 50% Opacity */ }
    <span 
        class="font-serif italic text-main/50 text-base tracking-wide select-none" 
        aria-current="page"
    >
        Page {page.currentPage} of {page.lastPage}
    </span>

    {/* 3. NEXT LINK */}
    {
        page.url.next ? (
            <a
                href={page.url.next}
                class="font-serif italic text-lg text-main/60 hover:text-main transition-colors"
                aria-label={`Go to page ${page.currentPage + 1} of ${page.lastPage}`}
            >
                Next &rarr;
            </a>
        ) : (
            /* Spacer */
            <span class="w-[60px]" aria-hidden="true"></span>
        )
    }
</nav>