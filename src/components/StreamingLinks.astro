---
import { platformIcons, platformLabels } from '../utils/platform-icons';

export interface StreamingLink {
	platform: 'spotify' | 'apple-music' | 'youtube-music' | 'amazon-music' | 'other';
	href: string;
}

interface Props {
	links: StreamingLink[];
}

const { links } = Astro.props;
---

<div class="flex flex-wrap gap-3 sm:gap-4">
	{links.map((link) => (
		<a
			href={link.href}
			rel="noopener noreferrer"
			target={link.href !== '#' ? '_blank' : undefined}
			title={platformLabels[link.platform]}
			class={`inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-full transition-colors ${
				link.href === '#'
					? 'bg-muted/20 border border-main/20 text-main/50 opacity-60 cursor-not-allowed'
					: 'bg-muted/40 border border-main/10 text-main hover:bg-muted/60 hover:border-main/30'
			}`}
		>
			{platformIcons[link.platform] ? (
				<svg
					class="w-6 h-6 sm:w-7 sm:h-7 fill-current"
					viewBox="0 0 16 16"
					set:html={platformIcons[link.platform]}
				/>
			) : null}
		</a>
	))}
</div>
