---
import type { ImageInput } from '../types';
import { getReleaseData, getReleaseLinks } from '../utils/get-release';
import { platformIcons, platformLabels } from '../utils/platform-icons';
import CustomImage from './CustomImage.astro';

export type PlatformLink = {
	platform: 'spotify' | 'apple-music' | 'youtube-music' | 'amazon-music' | 'other';
	href: string;
	label?: string;
};

type Props = {
	image?: ImageInput;
	links?: PlatformLink[];
	releaseId?: string;
};

const { image: propImage, links: propLinks, releaseId } = Astro.props;

let image = propImage;
let links = propLinks || [];

if (releaseId) {
	const releaseData = await getReleaseData(releaseId);
	if (releaseData) {
		image = releaseData.image;
		links = await getReleaseLinks(releaseId);
	}
}

const MAIN_PLATFORMS = ['spotify', 'apple-music', 'youtube-music', 'amazon-music'];
const mainLinks = links.filter((link) => MAIN_PLATFORMS.includes(link.platform));
const otherLinks = links.filter((link) => !MAIN_PLATFORMS.includes(link.platform));
---

<section class="mb-16 flex w-full flex-col gap-12 items-center sm:mb-24">
    {/* Centered Square Image */}
    <figure class="relative w-full max-w-xs aspect-square rounded-lg shadow-xl overflow-hidden bg-white dark:bg-muted">
        <CustomImage
            class="w-full h-full object-cover"
            {...image}
            widths={[300, 400]}
            sizes="(min-width: 400px) 400px, calc(100vw - 32px)"
            fetchpriority="high"
            loading="eager"
        />
    </figure>

    {/* Listen Now Section */}
    {links && links.length > 0 && (
        <div class="flex flex-col items-center gap-6">
            <h2 class="font-serif text-xl font-light text-main tracking-tight">Listen Now</h2>
            
            {/* Platform Buttons Row */}
            <div class="flex items-center justify-center gap-4 sm:gap-6 flex-wrap">
                {mainLinks.map((link) => {
                    const label = platformLabels[link.platform];
                    const isDisabled = link.href === '#';
                    const Element = isDisabled ? 'span' : 'a';
                    return (
                        <Element
                            href={isDisabled ? undefined : link.href}
                            target={isDisabled ? undefined : "_blank"}
                            rel={isDisabled ? undefined : "noopener noreferrer"}
                            class={`inline-flex items-center justify-center p-3 sm:p-4 rounded-full backdrop-blur-sm border transition-all duration-300 group ${isDisabled ? 'bg-muted/20 border-main/10 text-main/30 cursor-not-allowed' : 'bg-muted/40 border-main/30 hover:border-main hover:bg-muted/60 text-main hover:text-main'}`}
                            aria-label={`Listen on ${label}`}
                            title={label}
                        >
                            {platformIcons[link.platform] ? (
                                <svg class="w-6 h-6 sm:w-7 sm:h-7 fill-current" viewBox="0 0 16 16" set:html={platformIcons[link.platform]} />
                            ) : null}
                        </Element>
                    );
                })}

                {/* Other Options Dropdown */}
                {otherLinks.length > 0 && (
                    <div class="relative">
                        <button
                            type="button"
                            class="other-options-toggle inline-flex items-center justify-center p-3 sm:p-4 rounded-full bg-muted/40 backdrop-blur-sm border border-main/30 hover:border-main hover:bg-muted/60 transition-all duration-300 group text-main hover:text-main cursor-pointer"
                            aria-label="More options"
                            aria-expanded="false"
                            aria-haspopup="true"
                        >
                            {platformIcons['other'] ? (
                                <svg class="w-6 h-6 sm:w-7 sm:h-7 fill-current" viewBox="0 0 16 16" set:html={platformIcons['other']} />
                            ) : (
                                <span class="text-xl font-bold leading-none pb-2">...</span>
                            )}
                        </button>

                        <div
                            class="other-options-menu absolute top-full left-1/2 -translate-x-1/2 mt-2 w-48 py-2 bg-main/95 backdrop-blur-md rounded-xl shadow-xl border border-main/10 opacity-0 invisible transition-all duration-200 transform origin-top scale-95 z-50"
                        >
                            {otherLinks.map((link) => {
                                const isDisabled = link.href === '#';
                                const Element = isDisabled ? 'span' : 'a';
                                return (
                                    <Element
                                        href={isDisabled ? undefined : link.href}
                                        target={isDisabled ? undefined : "_blank"}
                                        rel={isDisabled ? undefined : "noopener noreferrer"}
                                    class={`block px-4 py-3 text-sm text-center transition-colors ${isDisabled ? 'text-main/40 cursor-not-allowed' : 'text-main/80 hover:text-main hover:bg-black/5 dark:hover:bg-white/10'}`}
                                    >
                                        {link.label || platformLabels[link.platform] || 'Other'}
                                    </Element>
                                );
                            })}
                        </div>
                    </div>
                )}
            </div>
        </div>
    )}
</section>

<script>
    function setupDropdowns() {
        const triggers = document.querySelectorAll('.other-options-toggle:not([data-initialized])');
        
        triggers.forEach(trigger => {
            trigger.setAttribute('data-initialized', 'true');
            const menu = trigger.nextElementSibling;
            if (!menu) return;

            trigger.addEventListener('click', (e) => {
                e.stopPropagation();
                const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
                
                // Close all other menus
                document.querySelectorAll('.other-options-toggle').forEach(t => {
                    if (t !== trigger) {
                        t.setAttribute('aria-expanded', 'false');
                        const m = t.nextElementSibling;
                        if (m) {
                            m.classList.add('opacity-0', 'invisible', 'scale-95');
                            m.classList.remove('opacity-100', 'visible', 'scale-100');
                        }
                    }
                });

                trigger.setAttribute('aria-expanded', (!isExpanded).toString());
                
                if (!isExpanded) {
                    menu.classList.remove('opacity-0', 'invisible', 'scale-95');
                    menu.classList.add('opacity-100', 'visible', 'scale-100');
                } else {
                    menu.classList.add('opacity-0', 'invisible', 'scale-95');
                    menu.classList.remove('opacity-100', 'visible', 'scale-100');
                }
            });
        });

        // Remove existing listener to prevent duplicates if setup runs multiple times
        document.removeEventListener('click', closeAllMenus);
        document.addEventListener('click', closeAllMenus);
    }

    function closeAllMenus(e: Event) {
        const triggers = document.querySelectorAll('.other-options-toggle[aria-expanded="true"]');
        triggers.forEach(trigger => {
            const menu = trigger.nextElementSibling;
            if (menu && !trigger.contains(e.target as Node) && !menu.contains(e.target as Node)) {
                trigger.setAttribute('aria-expanded', 'false');
                menu.classList.add('opacity-0', 'invisible', 'scale-95');
                menu.classList.remove('opacity-100', 'visible', 'scale-100');
            }
        });
    }

    setupDropdowns();
    document.addEventListener('astro:page-load', setupDropdowns);
</script>
