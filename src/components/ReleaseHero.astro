---
import type { ImageInput } from '../types';
import { getYouTubeVideoId } from '../utils/common-utils';
import { getReleaseData, getReleaseLinks } from '../utils/get-release';
import CustomImage from './CustomImage.astro';
import StreamingLinks from './StreamingLinks.astro';

type Props = {
	image?: ImageInput;
	releaseId?: string;
};

const { image: propImage, releaseId } = Astro.props;

let image = propImage;
let links: Awaited<ReturnType<typeof getReleaseLinks>> = [];
let youtubeUrl: string | undefined;
let title: string | undefined;

if (releaseId) {
	const releaseData = await getReleaseData(releaseId);
	if (releaseData) {
		image = releaseData.image;
		links = await getReleaseLinks(releaseId);
		youtubeUrl = releaseData.youtubeUrl;
		title = releaseData.title;
	}
}

const articleUrl = releaseId ? `/music/${releaseId}` : undefined;
const youtubeVideoId = getYouTubeVideoId(youtubeUrl);
---

<section class="mb-16 flex w-full flex-col gap-12 items-center sm:mb-24">
    {/* Title */}
    {title && (
        <h2 class="font-serif text-3xl sm:text-4xl font-light text-main tracking-tight text-center">
            {articleUrl ? <a href={articleUrl} class="hover:opacity-70 transition-opacity">{title}</a> : title}
        </h2>
    )}

    {/* YouTube Embed or Image */}
    {youtubeVideoId ? (
        <div class="relative w-full max-w-2xl aspect-video rounded-lg shadow-xl overflow-hidden bg-black">
            <iframe
                class="absolute inset-0 w-full h-full"
                src={`https://www.youtube.com/embed/${youtubeVideoId}`}
                title="YouTube video player"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
                loading="lazy"
            ></iframe>
        </div>
    ) : image ? (
        <figure class="relative w-full max-w-xs aspect-square rounded-lg shadow-xl overflow-hidden bg-white dark:bg-muted">
            <CustomImage
                class="w-full h-full object-cover"
                {...image}
                widths={[300, 400]}
                sizes="(min-width: 400px) 400px, calc(100vw - 32px)"
                fetchpriority="high"
                loading="eager"
            />
        </figure>
    ) : null}

    {/* Listen Now Section */}
    {links.length > 0 && (
        <div class="flex flex-col items-center gap-6">
            <h2 class="font-serif text-xl font-light text-main tracking-tight">Listen Now</h2>
            <StreamingLinks {links} />
            {articleUrl && (
                <a href={articleUrl} class="text-sm text-main hover:opacity-70 transition-opacity">
                    About this song →
                </a>
            )}
        </div>
    )}
</section>
